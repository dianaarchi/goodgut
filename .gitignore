# ── Environment ───────────────────────────────
.env
.envrc

# ── Node ──────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
.yarn/install-state.gz

# ── Output (rendered slides, temp files) ─────
output/*.png
output/*.jpg
output/*.jpeg
output/*.webp
output/*.json

# ── Assets (generated images, keep fonts tracked) ─────
assets/generated/*.png
assets/generated/*.jpg
assets/generated/*.webp

# ── OS ────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Logs ─────────────────────────────────────
*.log
logs/

# ── Python (keep from initial .gitignore) ─────
__pycache__/
*.py[codz]
*.egg-info/
.venv/
venv/
