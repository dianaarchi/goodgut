# ─────────────────────────────────────────────
# goodgut — environment variables
# Copy to .env and fill in real values.
# Never commit .env to version control.
#
# On the server:  /home/goodgut/goodgut/.env
# Permissions:    chmod 600 .env
# ─────────────────────────────────────────────

NODE_ENV=production

# ── Claude / Anthropic ───────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Instagram Graph API ───────────────────────
# Long-lived Page/User access token with permissions:
#   instagram_basic, instagram_content_publish,
#   pages_show_list, pages_read_engagement
# Generate via: Meta for Developers → Graph API Explorer
#   then exchange for a 60-day long-lived token
# Refresh this token before expiry (set a calendar reminder)
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here

# Numeric ID of the Instagram Business/Creator account
# Find via: GET /me/accounts → check connected IG account id
# or: GET /{page-id}?fields=instagram_business_account
INSTAGRAM_USER_ID=17841400000000000

# ── Meta App credentials ──────────────────────
# From: Meta for Developers → Your App → Settings → Basic
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here

# ── Pipeline config ───────────────────────────
# Timezone for cron scheduling (IANA format)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/Berlin

# Carousel post time (24h, HH:MM)
CAROUSEL_POST_TIME=09:00

# Stories post times, comma-separated (posted Mon/Wed/Fri by default)
STORIES_POST_TIMES=10:00,14:00,18:00

# ── Output ────────────────────────────────────
# Relative path where rendered PNGs are written before upload
OUTPUT_DIR=./output

# ── Image generation (Google AI Studio) ──────
# Get from: https://aistudio.google.com/apikey
# Used for Gemini image generation per carousel post
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Optional: appended to every image generation prompt for visual consistency
# Example: "brutalist graphic, acid green on black, bold typography"
IMAGE_STYLE=

# ── Optional: logging ─────────────────────────
# LOG_LEVEL options: error | warn | info | debug
LOG_LEVEL=info
